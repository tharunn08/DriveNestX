PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret

# Path to the SQLite database file. Defaults to ./data/drivenest.db if unset.
# On Render (or any host with an ephemeral filesystem), attach a persistent
# disk and point this at a file inside it, e.g. DB_PATH=/data/drivenest.db,
# or your data will be wiped on every redeploy/restart.
DB_PATH=./data/drivenest.db

# Set to "true" to allow POST /api/seed to run even when NODE_ENV=production.
# Useful for populating demo data once after your first deploy.
ALLOW_SEED=true
